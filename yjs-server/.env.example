# WebSocket port hocuspocus listens on.
PORT=1234

# Debounce window (ms) before persisting a document to the backend.
DEBOUNCE=1000

# Base URL of the Laravel API (must reach the backend over HTTP).
# In docker-compose this is the webserver service; locally use http://localhost:8000/api/v1.
API_URL=http://webserver/api/v1

# 'development' enables console logging; anything else logs only to files.
NODE_ENV=production
